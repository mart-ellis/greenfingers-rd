---
import Layout from "../layouts/Layout.astro";
export const prerender = true;
---

<Layout>

<h1>Films</h1>

<!-- Add film form -->
<form id="addFilmForm">
  <input name="title" placeholder="Title" required />
  <input name="year" type="number" placeholder="Year" required />
  <input name="director" placeholder="Director" required />
  <button type="submit">Add Film</button>
</form>

<hr />

<!-- Films list -->
<ul id="filmsList"></ul>

<script>
  const list = document.getElementById("filmsList");

  async function loadFilms() {
    const res = await fetch("/api/films");
    const films = await res.json();

    list.innerHTML = films
      .map(
        (f) => `
        <li>
          <strong>${f.title}</strong> (${f.year}) - ${f.director}

          <button data-id="${f.id}" class="deleteBtn">
            Delete
          </button>
        </li>
      `
      )
      .join("");

    // attach delete handlers
    document.querySelectorAll(".deleteBtn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;
        await fetch("/api/films/", {
          method: "DELETE",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({id}),
        });

        loadFilms();
      });
    });
  }

  // handle add form
  document
    .getElementById("addFilmForm")
    .addEventListener("submit", async (e) => {
      e.preventDefault();

      const form = e.target;

      const data = {
        title: form.title.value,
        year: Number(form.year.value),
        director: form.director.value,
      };

      await fetch("/api/films", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      form.reset();
      loadFilms();
    });

  // initial load
  loadFilms();
</script>
</Layout>